{
  "version": 3,
  "dependencies": {
    "services": [
      {
        "service": {
          "definitions": [
            {
              "definition": {
                "source": {
                  "filesystem": {
                    "directory": "./specs"
                  }
                },
                "specs": ["order.yaml"]
              }
            }
          ],
          "runOptions": {
            "openapi": {
              "type": "mock",
              "host": "localhost",
              "port": 9443,
              "cert": {
                "incomingMtlsEnabled": true,
                "keyStore": {
                  "file": "./certs/server.jks"
                },
                "keyStorePassword": "server-store-pass"
              }
            }
          }
        }
      }
    ]
  }
}
