{
  "defaultShell": "zsh",
  "defaultView": "list",
  "disableAutoMode": "enable",
  "permissions": {
    "disableAutoMode": "enable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo 'hook'",
            "shell": "zsh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
