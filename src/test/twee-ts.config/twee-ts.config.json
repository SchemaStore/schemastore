{
  "$schema": "https://unpkg.com/@rohal12/twee-ts/schemas/twee-ts.config.schema.json",
  "sources": ["src/"],
  "output": "story.html",
  "outputMode": "html",
  "formatId": "sugarcube-2",
  "startPassage": "Start",
  "formatPaths": ["/path/to/formats"],
  "formatIndices": ["https://example.com/index.json"],
  "formatUrls": ["https://example.com/format.js"],
  "useTweegoPath": true,
  "modules": ["module.js"],
  "headFile": "head.html",
  "trim": true,
  "twee2Compat": false,
  "testMode": false,
  "noRemote": false,
  "tagAliases": {
    "library": "script",
    "theme": "stylesheet"
  },
  "sourceInfo": false
}
