{
  "env": {
    "ANTHROPIC_BEDROCK_SERVICE_TIER": "flex",
    "CLAUDE_CODE_DEBUG_LOG_LEVEL": "error",
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh"
  },
  "permissions": {
    "allow": ["Read(~/.bashrc)", "Bash(pwd:*)"],
