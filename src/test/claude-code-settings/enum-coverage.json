{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "channelsEnabled": false,
  "defaultShell": "bash",
  "effortLevel": "xhigh",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo bash",
            "shell": "bash",
            "type": "command"
          },
          {
            "command": "Get-Content",
            "shell": "powershell",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "terminalTitleFromRename": true,
  "tui": "fullscreen",
  "viewMode": "verbose"
}
