{
  "defaultShell": "powershell",
  "defaultView": "chat",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo 'hook'",
            "shell": "bash",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "echo 'done'",
            "shell": "powershell",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "disableAutoMode": "disable"
  }
}
