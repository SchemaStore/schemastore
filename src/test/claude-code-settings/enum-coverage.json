{
  "$schema": "https://www.schemastore.org/claude-code-settings.json",
  "channelsEnabled": false,
  "defaultShell": "bash",
  "effortLevel": "xhigh",
  "env": {
    "CCR_FORCE_BUNDLE": "0",
    "CLAUDE_AGENT_SDK_DISABLE_BUILTIN_AGENTS": "0",
    "CLAUDE_AGENT_SDK_MCP_NO_PREFIX": "0",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "0",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "0",
    "CLAUDE_CODE_ACCESSIBILITY": "0",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "0",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "true",
    "CLAUDE_CODE_DEBUG_LOG_LEVEL": "verbose",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "0",
    "CLAUDE_CODE_DISABLE_CRON": "0",
    "CLAUDE_CODE_DISABLE_FAST_MODE": "0",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "0",
    "CLAUDE_CODE_DISABLE_FILE_CHECKPOINTING": "0",
    "CLAUDE_CODE_DISABLE_LEGACY_MODEL_REMAP": "0",
    "CLAUDE_CODE_DISABLE_MOUSE": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "0",
    "CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK": "0",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "0",
    "CLAUDE_CODE_DISABLE_POLICY_SKILLS": "0",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "0",
    "CLAUDE_CODE_DISABLE_THINKING": "0",
    "CLAUDE_CODE_DISABLE_VIRTUAL_SCROLL": "0",
    "CLAUDE_CODE_EFFORT_LEVEL": "low",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "0",
    "CLAUDE_CODE_ENABLE_BACKGROUND_PLUGIN_REFRESH": "0",
    "CLAUDE_CODE_ENABLE_FINE_GRAINED_TOOL_STREAMING": "0",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
    "CLAUDE_CODE_ENABLE_TASKS": "0",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_FORK_SUBAGENT": "0",
    "CLAUDE_CODE_GLOB_HIDDEN": "true",
    "CLAUDE_CODE_GLOB_NO_IGNORE": "true",
    "CLAUDE_CODE_HIDE_CWD": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "0",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "0",
    "CLAUDE_CODE_MCP_ALLOWLIST_ENV": "0",
    "CLAUDE_CODE_NEW_INIT": "0",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "CLAUDE_CODE_PERFORCE_MODE": "0",
    "CLAUDE_CODE_PLUGIN_KEEP_MARKETPLACE_ON_FAILURE": "0",
    "CLAUDE_CODE_PROVIDER_MANAGED_BY_HOST": "0",
    "CLAUDE_CODE_PROXY_RESOLVES_HOSTS": "0",
    "CLAUDE_CODE_REMOTE": "true",
    "CLAUDE_CODE_RESUME_INTERRUPTED_TURN": "0",
    "CLAUDE_CODE_SIMPLE": "0",
    "CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT": "0",
    "CLAUDE_CODE_SKIP_BEDROCK_AUTH": "0",
    "CLAUDE_CODE_SKIP_FOUNDRY_AUTH": "0",
    "CLAUDE_CODE_SKIP_MANTLE_AUTH": "0",
    "CLAUDE_CODE_SKIP_PROMPT_HISTORY": "0",
    "CLAUDE_CODE_SKIP_VERTEX_AUTH": "0",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "0",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL": "0",
    "CLAUDE_CODE_SYNTAX_HIGHLIGHT": "true",
    "CLAUDE_CODE_TMUX_TRUECOLOR": "0",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0",
    "DISABLE_AUTOUPDATER": "0",
    "DISABLE_ERROR_REPORTING": "0",
    "DISABLE_FEEDBACK_COMMAND": "0",
    "DISABLE_TELEMETRY": "0",
    "DISABLE_UPDATES": "0",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "true",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo bash",
            "shell": "bash",
            "type": "command"
          },
          {
            "command": "Get-Content",
            "shell": "powershell",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "terminalTitleFromRename": true,
  "tui": "fullscreen",
  "viewMode": "verbose"
}
