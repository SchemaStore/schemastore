{
  "variables": {
    "lang": "en"
  },
  "css": {
    "filters": "css",
    "profile": "css",
    "snippets": {
      "d": "display:${1:block};",
      "@i": "@import url(|);"
    },
    "abbreviations": {
      "m5": "margin: 0.5rem;"
    }
  },
  "html": {
    "extends": "xml",
    "filters": "html",
    "abbreviations": {
      "!": "<!DOCTYPE html>",
      "html:5": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"></head><body></body></html>"
    }
  }
}
