{
  "$schema": "../../schemas/json/intlayer.json",
  "content": {
    "conditionNode": {
      "condition": {
        "fallback": "Default action",
        "false": "Hide settings",
        "true": "Show settings"
      },
      "nodeType": "condition"
    },
    "enumerationNode": {
      "enumeration": {
        "fallback": "Many items",
        "0": "No items",
        "1": "One item"
      },
      "nodeType": "enumeration"
    },
    "fileNode": {
      "file": "/assets/images/logo.png",
      "nodeType": "file"
    },
    "genderNode": {
      "gender": "male",
      "nodeType": "gender"
    },
    "insertionNode": {
      "insertion": "Welcome, {username}!",
      "nodeType": "insertion"
    },
    "markdownNode": {
      "markdown": "# Header\nThis is **bold** text.",
      "nodeType": "markdown"
    },
    "nestedNode": {
      "nested": {
        "dictionaryKey": "common-strings",
        "path": "buttons.save"
      },
      "nodeType": "nested"
    },
    "nestedObject": {
      "deepArray": [true, false],
      "deepKey": "deep value"
    },
    "pluralNode": {
      "nodeType": "plural",
      "plural": {
        "few": "A few elements",
        "many": "Many elements",
        "one": "One element",
        "other": "Other count",
        "two": "Two elements",
        "zero": "No elements"
      }
    },
    "simpleArray": ["first", "second", 3, null],
    "simpleBoolean": true,
    "simpleNull": null,
    "simpleNumber": 123.45,
    "simpleString": "Hello world",
    "translationNode": {
      "nodeType": "translation",
      "translation": {
        "en": "Hello",
        "es": "Hola",
        "fr": "Bonjour"
      }
    }
  },
  "contentAutoTransformation": {
    "html": false,
    "insertion": true,
    "markdown": true
  },
  "description": "Configuration dictionary for app settings page",
  "fill": {
    "en": true,
    "es": false,
    "fr": "fallback-string"
  },
  "format": "intlayer",
  "id": "my-dictionary-id",
  "importMode": "static",
  "key": "app-settings",
  "locale": "en",
  "priority": 1,
  "tags": ["settings", "admin"],
  "title": "Application Settings"
}
