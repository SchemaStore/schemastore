{
  "$schema": "https://www.schemastore.org/yap.json",
  "buildDir": "/tmp/yap-build",
  "compressionDeb": "zstd",
  "compressionRpm": "xz",
  "debugDir": "/tmp/yap-debug",
  "description": "Project exercising every supported yap.json field",
  "name": "full-example",
  "output": "artifacts",
  "parallel": true,
  "projects": [
    { "description": "core library", "name": "foundation-lib" },
    { "install": true, "name": "main-app" }
  ],
  "repos": [
    {
      "components": ["main", "universe"],
      "distros": ["ubuntu"],
      "gpgCheck": true,
      "keyURL": "https://example.com/key.asc",
      "name": "extra",
      "suite": "jammy",
      "url": "https://example.com/apt"
    }
  ],
  "sbom": true,
  "sbomFormat": "both",
  "signing": {
    "Enabled": true,
    "KeyName": "release",
    "KeyPath": "/home/user/.config/yap/keys/deb.gpg"
  },
  "skipDeps": ["gcc"],
  "targetArch": "arm64"
}
