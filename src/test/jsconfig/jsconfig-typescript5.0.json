{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "customConditions": [""],
    "ignoreDeprecations": "5.0",
    "lib": [
      "decorators",
      "decorators.legacy",
      "es2022.regexp",
      "es2023",
      "es2023.array"
    ],
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "target": "es2023",
    "verbatimModuleSyntax": true
  }
}
