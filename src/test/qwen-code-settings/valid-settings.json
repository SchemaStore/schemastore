{
  "$schema": "./settings.schema.json",
  "$version": 3,
  "general": {
    "checkpointing": {
      "enabled": false
    },
    "defaultFileEncoding": "utf-8",
    "enableAutoUpdate": false,
    "gitCoAuthor": true,
    "preferredEditor": "nvim",
    "vimMode": true
  },
  "output": {
    "format": "text"
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "telemetry": {
    "enabled": false
  },
  "tools": {
    "useBuiltinRipgrep": false
  },
  "ui": {
    "customThemes": {
      "macchiato": {
        "AccentBlue": "#8aadf4",
        "Background": "#24273a",
        "Foreground": "#cad3f5",
        "GradientColors": ["#c6a0f6", "#8aadf4", "#7dc4e4"],
        "name": "macchiato",
        "type": "custom"
      }
    },
    "enableWelcomeBack": true,
    "hideBanner": true,
    "hideTips": true,
    "hideWindowTitle": true,
    "showCitations": true,
    "showLineNumbers": false,
    "theme": "macchiato"
  }
}
