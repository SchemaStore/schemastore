{
  "extract": {
    "connectionRef": "rest-api-connection",
    "restAPI": {
      "auth": {
        "clientId": "{{CLIENT_ID}}",
        "clientSecret": "{{CLIENT_SECRET}}",
        "scope": "read:data",
        "tokenUrl": "https://auth.example.com/oauth/token",
        "type": "oauth2_client_credentials"
      },
      "baseUrl": "https://api.example.com/v2",
      "defaults": {
        "headers": {
          "X-Api-Version": "2"
        },
        "pagination": {
          "cursorParam": "after",
          "cursorPath": "$.meta.next_cursor",
          "pageSize": 200,
          "type": "cursor"
        },
        "queryParams": {
          "format": "json"
        }
      },
      "endpoints": [
        {
          "as": "raw_customers",
          "children": [
            {
              "as": "customer_orders",
              "domain": "crm",
              "excludeFields": ["_internal.*", "debug_info"],
              "path": "/customers/{parent.id}/orders",
              "responsePath": "$.orders"
            }
          ],
          "domain": "crm",
          "incrementalField": "updated_at",
          "pagination": {
            "limitParam": "per_page",
            "pageParam": "page",
            "pageSize": 50,
            "type": "page_number"
          },
          "path": "/customers",
          "responsePath": "$.data"
        },
        {
          "domain": "catalog",
          "headers": {
            "Content-Type": "application/json"
          },
          "method": "POST",
          "pagination": {
            "limitParam": "take",
            "offsetParam": "skip",
            "pageSize": 100,
            "type": "offset"
          },
          "path": "/products",
          "queryParams": {
            "include_variants": "true"
          },
          "requestBody": "{\"filter\": \"active\"}",
          "responsePath": "$.products"
        },
        {
          "domain": "catalog",
          "pagination": {
            "pageSize": 500,
            "type": "link_header"
          },
          "path": "/inventory"
        }
      ],
      "headers": {
        "Accept": "application/json",
        "X-Request-Source": "starlake"
      },
      "rateLimit": {
        "requestsPerSecond": 5
      }
    }
  },
  "version": 1
}
