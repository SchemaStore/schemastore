{
  "extract": {
    "connectionRef": "api-spec-connection",
    "openAPI": {
      "basePath": "/api/v2",
      "domains": [
        {
          "basePath": "/api/v2/customers",
          "name": "customers",
          "routes": [
            {
              "exclude": ["/customers/internal"],
              "excludeFields": ["_links", "_metadata"],
              "explode": {
                "exclude": ["nested_internal"],
                "on": "OBJECT",
                "rename": {
                  "address_.*": "customer_address"
                }
              },
              "operations": ["GET", "POST"],
              "paths": ["/customers", "/customers/{id}"]
            }
          ],
          "schemas": {
            "exclude": ["CustomerInternal"],
            "include": ["Customer.*", "Address"]
          }
        }
      ],
      "formatTypeMapping": {
        "date-time": "timestamp",
        "email": "email",
        "uuid": "string"
      }
    },
    "sanitizeAttributeName": "ON_EXTRACT"
  },
  "version": 1
}
