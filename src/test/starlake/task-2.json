{
  "version": 1,
  "task": {
    "name": "scd2_customers",
    "domain": "warehouse",
    "table": "dim_customer",
    "writeStrategy": {
      "type": "SCD2",
      "key": ["customer_id"],
      "timestamp": "updated_at",
      "on": "SOURCE_AND_TARGET",
      "startTs": "valid_from",
      "endTs": "valid_to"
    },
    "sink": {
      "connectionRef": "snowflake-prod",
      "partition": ["region"],
      "clustering": ["customer_id"],
      "materializedView": "TABLE"
    },
    "rls": [
      {
        "name": "region_policy",
        "predicate": "region = current_user_region()",
        "grants": ["group:sales@company.com", "group:support@company.com"],
        "description": "Restrict access by region"
      }
    ],
    "acl": [
      {
        "role": "viewer",
        "grants": ["group:analysts@company.com"],
        "name": "analyst_read_access"
      }
    ],
    "attributes": [
      {
        "name": "customer_id",
        "type": "long",
        "required": true,
        "comment": "Unique customer identifier"
      },
      {
        "name": "email",
        "type": "email",
        "privacy": "SHA256",
        "accessPolicy": "pii_policy"
      },
      {
        "name": "region",
        "type": "string",
        "required": true
      }
    ]
  }
}