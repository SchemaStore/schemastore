{
  "load": {
    "comment": "E-commerce data domain with Kafka and XML ingestion support",
    "database": "ecommerce_db",
    "metadata": {
      "ack": "",
      "array": false,
      "dagRef": "ecommerce_load",
      "directory": "/data/incoming/ecommerce",
      "emptyIsNull": true,
      "encoding": "UTF-8",
      "extensions": [".json", ".xml", ".parquet"],
      "format": "JSON",
      "freshness": {
        "error": "3 hour",
        "warn": "1 hour"
      },
      "loader": "spark",
      "multiline": true,
      "nullValue": "\\N",
      "options": {
        "dateFormat": "yyyy-MM-dd",
        "timestampFormat": "yyyy-MM-dd'T'HH:mm:ss.SSSZ"
      },
      "schedule": "*/30 * * * *",
      "separator": "|",
      "sink": {
        "clustering": ["customer_id"],
        "coalesce": true,
        "connectionRef": "snowflake-prod",
        "enableRefresh": true,
        "extension": ".parquet",
        "format": "parquet",
        "id": "order_id",
        "materializedView": "TABLE",
        "options": {
          "compression": "snappy"
        },
        "partition": ["order_date"],
        "path": "/data/warehouse/ecommerce",
        "refreshIntervalMs": 3600000,
        "sharding": ["region"]
      },
      "withHeader": false,
      "writeStrategy": {
        "key": ["order_id"],
        "type": "DELETE_THEN_INSERT",
        "types": {
          "bigquery": "UPSERT_BY_KEY",
          "snowflake": "OVERWRITE_BY_PARTITION"
        }
      }
    },
    "name": "ecommerce",
    "rename": "ecommerce_v2",
    "tags": ["ecommerce", "production"]
  },
  "version": 1
}
