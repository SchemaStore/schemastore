{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://json.schemastore.org/venvplus-schema-v1.1.0.json",
  "$ref": "#/definitions/d5860/full",
  "type": "object",
  "title": "venvplus schema",
  "definitions": {
    "d5860": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "venvplus schema",
        "type": "object",
        "additionalProperties": false,
        "required": ["version"],
        "properties": {
          "version": {
            "$ref": "#/definitions/3c03b/full"
          },
          "offline-config": {
            "$ref": "#/definitions/cbf12/full"
          },
          "runtime-settings": {
            "$ref": "#/definitions/dd2a1/full"
          }
        }
      }
    },
    "cbf12": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Offline config",
        "description": "Settings for offline mode",
        "type": "object",
        "additionalProperties": false,
        "required": ["source-files"],
        "properties": {
          "source-files": {
            "description": "List of offline source files. A reference to a channel mapping set can be specified.",
            "type": "array",
            "items": {
              "$ref": "#/definitions/e9352/full"
            }
          },
          "processing-sequence": {
            "description": "Processing sequence of the offline sources.\n\"timestamp-only\": The offline sources are processed according to their timestamp, date and time are irrelevant.\n\"date-and-time\": The offline sources are processed according to date/time and the time stamp. Only available if all sources have absolute time stamps.\n\"source-file-sequence\": The offline sources are replayed in the order in which they are given in \"source-files\".",
            "default": "timestamp-only",
            "enum": ["timestamp-only", "date-and-time", "source-file-sequence"],
            "examples": [
              "timestamp-only",
              "date-and-time",
              "source-file-sequence"
            ]
          },
          "channel-mappings": {
            "$ref": "#/definitions/54ff4/full"
          },
          "default-channel-mapping": {
            "$ref": "#/definitions/9a523/full",
            "description": "Reference to a channel mapping set used for all source files, except if set explicitly in \"source-files\".",
            "examples": ["channelSet1"]
          }
        },
        "examples": [
          {
            "source-files": [
              {
                "file-path": ["path/to/my.blf", "path/to/another.blf"]
              }
            ]
          },
          {
            "source-files": [
              {
                "file-path": "path/to/my.blf"
              },
              {
                "file-path": "path/to/another.mf4"
              },
              {
                "file-path": "path/to/another.ttl"
              }
            ],
            "processing-sequence": "source-file-sequence",
            "default-channel-mapping": "set1",
            "channel-mappings": [
              {
                "name": "set1",
                "default-mapping": "as-in-original",
                "mappings": [
                  {
                    "source-channel": "Eth1",
                    "target-network": "AEthNetworkName",
                    "target-port": "APort"
                  },
                  {
                    "source-network": "ALINNetwork",
                    "target-network": "AnotherLIN"
                  },
                  {
                    "ignore-source-network": "CANnetwork"
                  },
                  {
                    "ignore-source-channel": "CAN1"
                  }
                ]
              }
            ]
          },
          {
            "source-files": [
              {
                "file-path": "path/to/my.blf",
                "channel-mapping": "set1"
              },
              {
                "file-path": "path/to/one.blf",
                "channel-mapping": "set2"
              }
            ],
            "channel-mappings": [
              {
                "name": "set1",
                "mappings": [
                  {
                    "ignore-source-channel": "CAN1"
                  }
                ]
              },
              {
                "name": "set2",
                "default-mapping": "ignore-all",
                "mappings": [
                  {
                    "source-network": "ALINNetwork",
                    "target-network": "AnotherLIN"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "dd2a1": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Runtime settings",
        "description": "Settings that change the runtime behavior of CANoe SE.",
        "type": "object",
        "additionalProperties": false,
        "minProperties": 1,
        "properties": {
          "fdx": {
            "$ref": "#/definitions/584d3/full"
          },
          "python": {
            "$ref": "#/definitions/0f0c2/full"
          },
          "sil-kit": {
            "$ref": "#/definitions/223dc/full"
          },
          "vector-hardware-manager": {
            "$ref": "#/definitions/83919/full"
          },
          "vt-system": {
            "$ref": "#/definitions/fd67c/full"
          },
          "xil": {
            "$ref": "#/definitions/88a2e/full"
          }
        },
        "examples": [
          {
            "vector-hardware-manager": {
              "application-name": "CANoeB",
              "prefixed-ethernet-networks": ["Ethernet1", "Ethernet2"]
            }
          },
          {
            "vt-system": {
              "adapter-name": "A network adapter name"
            }
          },
          {
            "python": {
              "virtual-environment-path": "workingDir/.venv"
            }
          },
          {
            "xil": {
              "port": 123
            }
          },
          {
            "fdx": {
              "port": 234
            }
          },
          {
            "sil-kit": {
              "config-file-path": "sil-kit-file.json",
              "life-cycle-event-timeout-in-sec": 5
            }
          }
        ]
      }
    },
    "e9352": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "required": ["file-path"],
        "properties": {
          "file-path": {
            "oneOf": [
              {
                "$ref": "#/definitions/5d5ac/full"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/5d5ac/full"
                }
              }
            ],
            "examples": [
              "path/to/my.blf",
              "path/to/my.mf4",
              ["path/to/my.blf"],
              ["path/to/my.blf", "path/to/another.mf4"]
            ]
          },
          "channel-mapping": {
            "$ref": "#/definitions/9a523/full",
            "description": "Name of a channel mapping set defined in \"channel-mapping\"."
          }
        }
      }
    },
    "fd67c": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "VT System settings",
        "description": "Settings that change VT System.\nRequires that a VT System is configured in the environment.\nCannot be used in offline mode.",
        "type": "object",
        "additionalProperties": false,
        "required": ["adapter-name"],
        "properties": {
          "adapter-name": {
            "description": "The name of the network adapter which should be used by the VT System.",
            "type": "string",
            "examples": ["A network adapter name"]
          }
        }
      }
    },
    "fe601": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Channel mapping",
        "description": "A channel mapping for one or more offline sources.",
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "$ref": "#/definitions/9a523/full",
            "description": "A C-identifier for this element (case sensitive)."
          },
          "default-mapping": {
            "description": "The default mapping of a channel if not explicitly mapped.",
            "default": "as-in-original",
            "oneOf": [
              {
                "const": "as-in-original",
                "description": "The channel is mapped to itself if there is an active network."
              },
              {
                "const": "ignore-all",
                "description": "The channels are ignored by default."
              }
            ],
            "examples": ["as-in-original", "ignore-all"]
          },
          "mappings": {
            "title": "Explicit mappings",
            "description": "The explicitly mapped channels. Overwrites the default mapping for the source.",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "title": "Map source channel",
                  "type": "object",
                  "description": "Mapping from application channel of the replay file to a target network.",
                  "additionalProperties": false,
                  "required": ["source-channel", "target-network"],
                  "properties": {
                    "source-channel": {
                      "description": "The source application channel for a given network type from the replayed file.",
                      "anyOf": [
                        {
                          "$ref": "#/definitions/d9e2f/full"
                        },
                        {
                          "$ref": "#/definitions/1b26c/full"
                        },
                        {
                          "$ref": "#/definitions/a8944/full"
                        }
                      ]
                    },
                    "target-network": {
                      "$ref": "#/definitions/9a523/full",
                      "description": "The target network name."
                    }
                  }
                },
                {
                  "title": "Map source channel",
                  "type": "object",
                  "description": "The source application channel for a given network type from the replayed file.",
                  "additionalProperties": false,
                  "required": ["source-channel", "target-network"],
                  "properties": {
                    "source-channel": {
                      "$ref": "#/definitions/56e73/full",
                      "description": "The source bus type and application channel from the replayed file."
                    },
                    "target-network": {
                      "$ref": "#/definitions/9a523/full",
                      "description": "The target network name."
                    },
                    "target-port": {
                      "$ref": "#/definitions/9a523/full",
                      "description": "Target port (applies to Ethernet networks only)."
                    }
                  }
                },
                {
                  "title": "Map source network",
                  "type": "object",
                  "description": "Mapping from a named source network of the replay file to a named target network.",
                  "additionalProperties": false,
                  "required": ["source-network", "target-network"],
                  "properties": {
                    "source-network": {
                      "description": "The source network name. Only works if the replay file was created by CANoe and contains the relevant metadata.",
                      "type": "string"
                    },
                    "target-network": {
                      "description": "The target network name.",
                      "oneOf": [
                        {
                          "$ref": "#/definitions/9a523/full"
                        }
                      ]
                    },
                    "target-port": {
                      "$ref": "#/definitions/9a523/full",
                      "description": "Target port (applies to Ethernet networks only)."
                    }
                  }
                },
                {
                  "title": "Ignore source channel",
                  "type": "object",
                  "description": "Ignores an application channel of the replay file.",
                  "additionalProperties": false,
                  "required": ["ignore-source-channel"],
                  "properties": {
                    "ignore-source-channel": {
                      "description": "The ignored source channel",
                      "oneOf": [
                        {
                          "$ref": "#/definitions/d9e2f/full"
                        },
                        {
                          "$ref": "#/definitions/1b26c/full"
                        },
                        {
                          "$ref": "#/definitions/a8944/full"
                        },
                        {
                          "$ref": "#/definitions/56e73/full"
                        }
                      ]
                    }
                  }
                },
                {
                  "title": "Ignore source network",
                  "type": "object",
                  "description": "Ignores a named source network of the replay file.",
                  "additionalProperties": false,
                  "required": ["ignore-source-network"],
                  "properties": {
                    "ignore-source-network": {
                      "description": "The ignored source network name. Only works if the replay file was created by CANoe and contains the relevant metadata.",
                      "type": "string"
                    }
                  },
                  "examples": [
                    {
                      "ignore-source-network": "networkName"
                    }
                  ]
                }
              ]
            }
          }
        },
        "examples": []
      }
    },
    "a63a9": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "description": "Absolute or relative path to a SIL Kit config file (.yaml/.json). Relative path specifications are resolved relative to the configuration file.",
        "type": "string",
        "anyOf": [
          {
            "pattern": "^.*\\.[yY][aA][mM][lL]$"
          },
          {
            "pattern": "^.*\\.[jJ][sS][oO][nN]$"
          }
        ],
        "examples": ["path/to/myConfigFile.json", "path/to/myConfigFile.yaml"]
      }
    },
    "d9e2f": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "string",
        "pattern": "^((CAN)([1-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5]))$",
        "examples": ["CAN1", "CAN255"]
      }
    },
    "a8944": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "string",
        "pattern": "^((FlexRay)([1-9]|[12][0-9]|3[0-2]))$",
        "examples": ["FlexRay1", "FlexRay32"]
      }
    },
    "3c03b": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Version",
        "description": "Json schema version for the venvplus configuration file. Acceptance criteria: equal major version, less/equal minor and patch version.",
        "const": "1.1.0",
        "type": "string",
        "examples": ["1.1.0"]
      }
    },
    "54ff4": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Channel mappings",
        "description": "List of channel mappings.",
        "type": "array",
        "items": {
          "$ref": "#/definitions/fe601/full"
        }
      }
    },
    "9a523": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "string",
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "examples": ["myid", "THIS_IS_CASE_SENSITIVE", "__1_2_3_4_5__"]
      }
    },
    "584d3": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "FDX settings",
        "description": "Settings that change the behavior of FDX.\nRequires that FDX is configured in the environment.\nCannot be used in offline mode.",
        "type": "object",
        "additionalProperties": false,
        "required": ["port"],
        "properties": {
          "port": {
            "description": "Overrides the UDP or TCP port for the FDX protocol.",
            "type": "integer",
            "minimum": 0,
            "maximum": 65535,
            "examples": [3030]
          }
        }
      }
    },
    "0f0c2": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Python settings",
        "description": "Settings that change the behavior of Python.",
        "type": "object",
        "additionalProperties": false,
        "required": ["virtual-environment-path"],
        "properties": {
          "virtual-environment-path": {
            "description": "Select a virtual environment folder. The path includes the directory of the virtual environment.",
            "type": "string",
            "examples": ["workingDir/.venv", ".venv", "C/Files/.venv"]
          }
        }
      }
    },
    "223dc": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "SIL Kit settings",
        "description": "Settings that change the behavior of SIL Kit.\nRequires that SIL Kit is configured in the environment.\nCannot be used in offline mode.",
        "type": "object",
        "additionalProperties": false,
        "minProperties": 1,
        "properties": {
          "config-file-path": {
            "$ref": "#/definitions/a63a9/full"
          },
          "life-cycle-event-timeout-in-sec": {
            "description": "Maximum waiting time for the other simulation participants. Valid only when \"time-source\" is set to \"external-sil-kit\" in the environment.",
            "type": "integer",
            "minimum": 0,
            "maximum": 9223372036
          }
        }
      }
    },
    "83919": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Vector Hardware Manager settings",
        "description": "Settings that change the interaction between CANoe SE and the Vector Hardware Manager.",
        "type": "object",
        "additionalProperties": false,
        "required": ["application-name"],
        "properties": {
          "application-name": {
            "$ref": "#/definitions/9a523/full",
            "description": "CANoe SE will start with this application name. The application name is used for channel assignment in the Vector Hardware Manager.",
            "examples": ["CANoe2"]
          },
          "prefixed-ethernet-networks": {
            "description": "List of ethernet network names to which a prefix should be added in a environment when it is opened.\nThe prefix consists of the application name with a separating \"_\" which will be added to the network names.\nIf this property is not present, all ethernet networks receive the prefix.",
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/definitions/9a523/full"
            },
            "examples": [["Ethernet1", "Ethernet2"]]
          }
        }
      }
    },
    "88a2e": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "XIL API Settings",
        "description": "Settings that change the behavior of the XIL API server.\nCannot be used in offline mode.",
        "type": "object",
        "additionalProperties": false,
        "required": ["port"],
        "properties": {
          "port": {
            "description": "Overrides the TCP port to be used by the XIL API",
            "type": "integer",
            "minimum": 0,
            "maximum": 65535,
            "examples": [5555]
          }
        }
      }
    },
    "5d5ac": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "description": "Absolute or relative path to a frame logging file (.blf/.mf4/.ttl). Relative path specifications are resolved relative to the configuration file.\n.mf4 and .ttl are not supported for target architecture Linux64.",
        "type": "string",
        "anyOf": [
          {
            "pattern": "^.*\\.[bB][lL][fF]$"
          },
          {
            "pattern": "^.*\\.[mM][fF]4$"
          },
          {
            "pattern": "^.*\\.[tT][tT][lL]$"
          }
        ]
      }
    },
    "1b26c": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "string",
        "pattern": "^((LIN)([1-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5]))$",
        "examples": ["LIN1", "LIN255"]
      }
    },
    "56e73": {
      "full": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "string",
        "pattern": "^((Eth)([1-9]|[12][0-9]|3[0-2]))$",
        "examples": ["Eth1", "Eth32"]
      }
    }
  }
}
