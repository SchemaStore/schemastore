{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.schemastore.org/package-lock-3.json",
  "additionalProperties": true,
  "description": "NPM package lockfile, version 3",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "https://www.schemastore.org/package-lock-2.json#/properties/name"
    },
    "lockfileVersion": {
      "$ref": "https://www.schemastore.org/package-lock.json#/properties/lockfileVersion",
      "const": 3
    },
    "packages": {
      "$ref": "https://www.schemastore.org/package-lock-2.json#/definitions/packages"
    },
    "requires": {
      "$ref": "https://www.schemastore.org/package-lock-2.json#/properties/requires"
    },
    "version": {
      "$ref": "https://www.schemastore.org/package-lock-2.json#/properties/version"
    }
  },
  "required": ["name", "version", "lockfileVersion"]
}
