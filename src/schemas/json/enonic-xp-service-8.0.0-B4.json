{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://json.schemastore.org/enonic-xp-service-8.0.0-B4.json",
    "type": "object",
    "properties": {
        "kind": {
            "type": "string",
            "const": "Service"
        },
        "allow": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "title": {
            "$ref": "#/$defs/localizedTextDef"
        }
    },
    "required": [
        "kind"
    ],
    "additionalProperties": false,
    "$defs": {
        "localizedTextDef": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "properties": {
                        "text": {
                            "type": "string"
                        },
                        "i18n": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "text"
                    ],
                    "additionalProperties": false
                }
            ]
        }
    }
}
